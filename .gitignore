# ═══════════════════════════════════════
# PageLink - Reglas de Git
# ═══════════════════════════════════════

# Base de datos (contiene datos sensibles)
database.sqlite
database.sqlite-journal
database.sqlite-wal
database.sqlite-shm
database.php

# Imagenes subidas por usuarios (avatars y portadas)
uploads/avatar_*
uploads/cover_*
!uploads/default.jpg

# Archivos de sistema
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# Archivos de IDE/editores
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Archivos de dependencias
node_modules/
vendor/
composer.lock

# Archivos temporales
*.tmp
*.log
*.cache

# Variables de entorno
.env
.env.local
.env.production

# Archivos de backup
*.bak
*.backup
backups/
